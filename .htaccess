# Serve foo.html when /foo is requested, without changing the URL shown in
# the browser (internal rewrite, not a redirect).
RewriteEngine On

# If someone requests the .html URL directly, send them to the clean version
# instead (permanent redirect), so there's only ever one canonical URL per page.
RewriteCond %{THE_REQUEST} \s/+([^?\s]+)\.html[\s?] [NC]
RewriteRule ^ /%1 [R=301,L]

# Internally rewrite the clean URL to the matching .html file on disk.
RewriteCond %{REQUEST_FILENAME} !-d
RewriteCond %{REQUEST_FILENAME}.html -f
RewriteRule ^([^.]+)$ $1.html [NC,L]
